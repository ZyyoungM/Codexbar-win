<Window x:Class="CodexBar.Win.AddCompatibleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加兼容 Provider"
        Width="640"
        Height="700"
        MinWidth="520"
        MinHeight="540"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="#FFF5F5F5"
        FontFamily="Microsoft YaHei UI"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
  <Window.Resources>
    <Style x:Key="SectionCard" TargetType="Border">
      <Setter Property="Padding" Value="14" />
      <Setter Property="Margin" Value="0,0,0,12" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#11000000" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#1C1C1C" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#605E5C" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="FieldInput" TargetType="TextBox">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="BorderBrush" Value="#D9D9D9" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="#1C1C1C" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style TargetType="PasswordBox">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="BorderBrush" Value="#D9D9D9" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="#1C1C1C" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="ActionButton" TargetType="Button">
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#1C1C1C" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#D9D9D9" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="#0067C0" />
      <Setter Property="BorderBrush" Value="#0067C0" />
    </Style>

    <Style x:Key="SubtleButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
      <Setter Property="Background" Value="#FFF5F5F5" />
      <Setter Property="BorderBrush" Value="#FFF5F5F5" />
      <Setter Property="FontWeight" Value="Normal" />
    </Style>
  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Style="{StaticResource SectionCard}"
            Background="#F7FAFF"
            BorderBrush="#CFE4F9">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock Text="添加兼容 Provider"
                     Foreground="#1C1C1C"
                     FontSize="17"
                     FontWeight="SemiBold" />
          <TextBlock Margin="0,6,0,0"
                     Text="为兼容 OpenAI API 的第三方 Provider 添加本地配置。只会更新当前激活态，不会改写历史会话。"
                     Foreground="#605E5C"
                     FontSize="11"
                     TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Column="1"
                Margin="12,0,0,0"
                Padding="8,3"
                Background="#E7F1FB"
                CornerRadius="8"
                VerticalAlignment="Top">
          <TextBlock Text="本地配置"
                     Foreground="#0067C0"
                     FontSize="10"
                     FontWeight="SemiBold" />
        </Border>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel>
        <Border Style="{StaticResource SectionCard}"
                Background="#FFF8E7"
                BorderBrush="#F1D38B">
          <TextBlock Text="必填项只有 Provider ID、Base URL、账号 ID 和 API Key。Provider 名称与账号显示名留空时，会自动回退为更简洁的默认值。"
                     Foreground="#5C4A1A"
                     FontSize="11"
                     TextWrapping="Wrap" />
        </Border>

        <Border Style="{StaticResource SectionCard}">
          <StackPanel>
            <TextBlock Text="Provider 信息" Style="{StaticResource SectionTitle}" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource FieldLabel}">
                  <Run Text="Provider ID" />
                  <Run Text=" *" Foreground="#C42B1C" />
                </TextBlock>
                <TextBox x:Name="ProviderIdBox"
                         Style="{StaticResource FieldInput}"
                         Text="compatible" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#8A8886"
                           FontSize="10"
                           Text="仅作为本地唯一标识，建议使用英文小写或下划线。" />
              </StackPanel>

              <StackPanel Grid.Column="2">
                <TextBlock Text="Provider 名称（可选）" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="ProviderNameBox"
                         Style="{StaticResource FieldInput}"
                         Text="兼容 API" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#8A8886"
                           FontSize="10"
                           Text="用于主浮窗里的展示名称。" />
              </StackPanel>
            </Grid>

            <TextBlock Margin="0,14,0,0" Style="{StaticResource FieldLabel}">
              <Run Text="Base URL" />
              <Run Text=" *" Foreground="#C42B1C" />
            </TextBlock>
            <TextBox x:Name="BaseUrlBox"
                     Style="{StaticResource FieldInput}"
                     Text="https://api.example.com/v1" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#8A8886"
                       FontSize="10"
                       Text="请填写到 OpenAI 兼容接口根路径，例如 https://api.example.com/v1。" />
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCard}">
          <StackPanel>
            <TextBlock Text="账号信息" Style="{StaticResource SectionTitle}" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource FieldLabel}">
                  <Run Text="账号 ID" />
                  <Run Text=" *" Foreground="#C42B1C" />
                </TextBlock>
                <TextBox x:Name="AccountIdBox"
                         Style="{StaticResource FieldInput}"
                         Text="default" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#8A8886"
                           FontSize="10"
                           Text="同一 Provider 下的账号唯一标识。" />
              </StackPanel>

              <StackPanel Grid.Column="2">
                <TextBlock Text="账号显示名（可选）" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="AccountLabelBox"
                         Style="{StaticResource FieldInput}"
                         Text="默认" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#8A8886"
                           FontSize="10"
                           Text="用于账号卡片标题展示。" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCard}">
          <StackPanel>
            <TextBlock Text="认证信息" Style="{StaticResource SectionTitle}" />
            <TextBlock Style="{StaticResource FieldLabel}">
              <Run Text="API Key" />
              <Run Text=" *" Foreground="#C42B1C" />
            </TextBlock>
            <PasswordBox x:Name="ApiKeyBox" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#8A8886"
                       FontSize="10"
                       Text="只写入本地凭据存储，不会出现在历史会话池里。" />
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCard}">
          <Expander Header="高级选项" IsExpanded="False">
            <StackPanel Margin="0,10,0,0">
              <TextBlock Text="Codex Provider ID（可选）" Style="{StaticResource FieldLabel}" />
              <TextBox x:Name="CodexProviderIdBox"
                       Style="{StaticResource FieldInput}"
                       Text="openai" />
              <TextBlock Margin="0,6,0,0"
                         Foreground="#8A8886"
                         FontSize="10"
                         Text="大多数兼容 OpenAI 的 Provider 保持默认 openai 即可，仅在需要兼容特定历史过滤逻辑时再修改。" />
            </StackPanel>
          </Expander>
        </Border>

        <Border x:Name="StatusPanel"
                Style="{StaticResource SectionCard}"
                Margin="0,0,0,0"
                Background="#F7FAFF"
                BorderBrush="#CFE4F9"
                Visibility="Collapsed">
          <StackPanel>
            <TextBlock x:Name="StatusTitleText"
                       Foreground="#0F6CBD"
                       FontSize="12"
                       FontWeight="SemiBold" />
            <TextBlock x:Name="StatusBodyText"
                       Margin="0,6,0,0"
                       Foreground="#605E5C"
                       FontSize="11"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2"
            Margin="0,12,0,0"
            Padding="12"
            Background="White"
            BorderBrush="#11000000"
            BorderThickness="1"
            CornerRadius="8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock VerticalAlignment="Center"
                   Foreground="#605E5C"
                   FontSize="10"
                   Text="切换只影响新会话；当前窗口不会改写 sessions / archived_sessions。" />

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
          <Button Content="取消"
                  Width="78"
                  Margin="0,0,8,0"
                  Style="{StaticResource SubtleButton}"
                  Click="Cancel_Click" />
          <Button x:Name="ProbeButton"
                  Content="测试连接"
                  Width="92"
                  Margin="0,0,8,0"
                  Style="{StaticResource ActionButton}"
                  Click="Probe_Click" />
          <Button x:Name="SaveButton"
                  Content="保存"
                  Width="78"
                  Style="{StaticResource PrimaryButton}"
                  Click="Save_Click" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
