<Window x:Class="CodexBar.Win.AddCompatibleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="&#x6DFB;&#x52A0;&#x517C;&#x5BB9; Provider"
        Width="460"
        Height="500"
        MinWidth="380"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        ShowInTaskbar="True">
  <Border Padding="16">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel>
        <TextBlock Text="&#x5E26; * &#x4E3A;&#x5FC5;&#x586B;&#x3002;&#x7B2C;&#x4E09;&#x65B9; OpenAI &#x517C;&#x5BB9;&#x4E2D;&#x8F6C;&#x7AD9;&#x81F3;&#x5C11;&#x9700;&#x8981; Base URL &#x548C; API Key&#xFF1B;&#x672C;&#x5DE5;&#x5177;&#x53E6;&#x5916;&#x9700;&#x8981; Provider ID &#x548C;&#x8D26;&#x53F7; ID &#x4F5C;&#x4E3A;&#x672C;&#x5730;&#x552F;&#x4E00;&#x6807;&#x8BC6;&#x3002;"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />
        <TextBlock Text="* Provider ID" />
        <TextBox x:Name="ProviderIdBox" Text="compatible" Margin="0,2,0,10" />
        <TextBlock Text="Provider &#x540D;&#x79F0;&#xFF08;&#x53EF;&#x9009;&#xFF09;" />
        <TextBox x:Name="ProviderNameBox" Text="&#x517C;&#x5BB9; API" Margin="0,2,0,10" />
        <TextBlock Text="* Base URL" />
        <TextBox x:Name="BaseUrlBox" Text="https://api.example.com/v1" Margin="0,2,0,10" />
        <TextBlock Text="* &#x8D26;&#x53F7; ID" />
        <TextBox x:Name="AccountIdBox" Text="default" Margin="0,2,0,10" />
        <TextBlock Text="&#x8D26;&#x53F7;&#x663E;&#x793A;&#x540D;&#xFF08;&#x53EF;&#x9009;&#xFF09;" />
        <TextBox x:Name="AccountLabelBox" Text="&#x9ED8;&#x8BA4;" Margin="0,2,0,10" />
        <TextBlock Text="* API Key" />
        <PasswordBox x:Name="ApiKeyBox" Margin="0,2,0,12" />
        <TextBlock Text="Base URL &#x8BF7;&#x586B;&#x5199;&#x5230; OpenAI &#x517C;&#x5BB9;&#x63A5;&#x53E3;&#x6839;&#x8DEF;&#x5F84;&#xFF0C;&#x4F8B;&#x5982;&#xFF1A;https://api.example.com/v1"
                   Foreground="#666666"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />
        <Expander Header="高级兼容选项" IsExpanded="False" Margin="0,0,0,12">
          <StackPanel Margin="0,8,0,0">
            <TextBlock Text="Codex Provider ID（可选，默认 openai，仅用于兼容 Codex 的 provider / 历史过滤）"
                       TextWrapping="Wrap" />
            <TextBox x:Name="CodexProviderIdBox" Text="openai" Margin="0,2,0,8" />
            <TextBlock Text="普通第三方 API 场景保持默认即可；只有需要显式改写 Codex 侧 provider 标识时再展开这里。"
                       Foreground="#666666"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Expander>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="&#x53D6;&#x6D88;" Width="72" Margin="0,0,8,0" Click="Cancel_Click" />
          <Button Content="&#x4FDD;&#x5B58;" Width="72" Click="Save_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Border>
</Window>
