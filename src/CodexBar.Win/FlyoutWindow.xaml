<Window x:Class="CodexBar.Win.FlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CodexBar"
        Width="430"
        Height="780"
        MinWidth="430"
        MinHeight="620"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="False"
        Background="#FFF5F5F5"
        FontFamily="Microsoft YaHei UI"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

    <Style x:Key="BaseActionButton" TargetType="Button">
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="10,0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#1C1C1C" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#D9D9D9" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource BaseActionButton}">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="#0067C0" />
      <Setter Property="BorderBrush" Value="#0067C0" />
    </Style>

    <Style x:Key="SecondaryActionButton" TargetType="Button" BasedOn="{StaticResource BaseActionButton}">
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#D9D9D9" />
    </Style>

    <Style x:Key="SubtleActionButton" TargetType="Button" BasedOn="{StaticResource BaseActionButton}">
      <Setter Property="Background" Value="#FFF5F5F5" />
      <Setter Property="BorderBrush" Value="#FFF5F5F5" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Height" Value="32" />
    </Style>

    <Style x:Key="TopActionButton" TargetType="Button" BasedOn="{StaticResource BaseActionButton}">
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="9,0" />
      <Setter Property="FontSize" Value="10" />
    </Style>

    <Style x:Key="TopPrimaryActionButton" TargetType="Button" BasedOn="{StaticResource TopActionButton}">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="#0067C0" />
      <Setter Property="BorderBrush" Value="#0067C0" />
    </Style>

    <Style x:Key="TopSecondaryActionButton" TargetType="Button" BasedOn="{StaticResource TopActionButton}">
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#D9D9D9" />
    </Style>

    <Style x:Key="TopSubtleActionButton" TargetType="Button" BasedOn="{StaticResource TopActionButton}">
      <Setter Property="Background" Value="#FFF5F5F5" />
      <Setter Property="BorderBrush" Value="#FFF5F5F5" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <Style x:Key="ToolbarIconButton" TargetType="Button" BasedOn="{StaticResource BaseActionButton}">
      <Setter Property="Height" Value="34" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,6,0" />
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="Normal" />
    </Style>

    <Style x:Key="ToolbarPrimaryIconButton" TargetType="Button" BasedOn="{StaticResource ToolbarIconButton}">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="#0067C0" />
      <Setter Property="BorderBrush" Value="#0067C0" />
    </Style>

    <Style x:Key="MiniSecondaryButton" TargetType="Button" BasedOn="{StaticResource BaseActionButton}">
      <Setter Property="Height" Value="26" />
      <Setter Property="MinWidth" Value="54" />
      <Setter Property="Padding" Value="8,0" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="Normal" />
    </Style>

    <Style x:Key="MiniPrimaryButton" TargetType="Button" BasedOn="{StaticResource MiniSecondaryButton}">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="#0067C0" />
      <Setter Property="BorderBrush" Value="#0067C0" />
    </Style>

    <Style x:Key="TierBadgeBorder" TargetType="Border">
      <Setter Property="Margin" Value="0,0,8,4" />
      <Setter Property="Padding" Value="6,2" />
      <Setter Property="Background" Value="#F3F3F3" />
      <Setter Property="BorderBrush" Value="#D9D9D9" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="IconActionButton" TargetType="Button">
      <Setter Property="Width" Value="24" />
      <Setter Property="Height" Value="24" />
      <Setter Property="Margin" Value="4,0,0,0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="#605E5C" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#11000000" />
                <Setter Property="Foreground" Value="#1C1C1C" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.35" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="RoutingSegmentButtonBase" TargetType="Button">
      <Setter Property="Height" Value="30" />
      <Setter Property="MinWidth" Value="42" />
      <Setter Property="Padding" Value="8,0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#605E5C" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="Normal" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ManualRoutingButtonStyle" TargetType="Button" BasedOn="{StaticResource RoutingSegmentButtonBase}">
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsManualRouting}" Value="True">
          <Setter Property="Background" Value="White" />
          <Setter Property="Foreground" Value="#1C1C1C" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="AutomaticRoutingButtonStyle" TargetType="Button" BasedOn="{StaticResource RoutingSegmentButtonBase}">
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsAutomaticRouting}" Value="True">
          <Setter Property="Background" Value="White" />
          <Setter Property="Foreground" Value="#1C1C1C" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="SectionCard" TargetType="Border">
      <Setter Property="Padding" Value="10" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#11000000" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="AccountCardStyle" TargetType="Border" BasedOn="{StaticResource SectionCard}">
      <Setter Property="Margin" Value="0,0,0,9" />
      <Setter Property="BorderBrush" Value="#11000000" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding DataContext.IsCompactCardDensity, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="True">
          <Setter Property="Padding" Value="7" />
          <Setter Property="Margin" Value="0,0,0,6" />
        </DataTrigger>
        <DataTrigger Binding="{Binding IsActive}" Value="True">
          <Setter Property="BorderBrush" Value="#0067C0" />
          <Setter Property="Background" Value="#FAFBFE" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style TargetType="ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <ContentPresenter />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border Padding="10" Background="#FFF5F5F5">
    <Grid x:Name="RootGrid">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" Margin="0,0,0,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <UniformGrid Columns="6"
                     Margin="0,0,6,0"
                     VerticalAlignment="Center">
          <Button Content="&#xE8D4;"
                  Style="{StaticResource ToolbarPrimaryIconButton}"
                  ToolTip="添加 OpenAI 授权"
                  Click="OAuth_Click" />
          <Button Content="&#xE710;"
                  Style="{StaticResource ToolbarIconButton}"
                  ToolTip="添加兼容 Provider"
                  Click="AddCompatible_Click" />
          <Button Content="&#xE72C;"
                  Style="{StaticResource ToolbarIconButton}"
                  ToolTip="刷新状态 / 额度 / API"
                  Click="ProbeAll_Click" />
          <Button Content="&#xE768;"
                  Style="{StaticResource ToolbarPrimaryIconButton}"
                  ToolTip="启动 Codex"
                  IsEnabled="{Binding HasActiveAccount}"
                  Click="ActiveLaunch_Click" />
          <Button Content="&#xE7F4;"
                  Style="{StaticResource ToolbarIconButton}"
                  ToolTip="显示小浮窗"
                  Click="Overlay_Click" />
          <Button Content="&#xE713;"
                  Style="{StaticResource ToolbarIconButton}"
                  ToolTip="打开设置"
                  Click="Settings_Click" />
        </UniformGrid>

        <Border Grid.Column="1"
                Padding="2"
                Background="#EFEFEF"
                CornerRadius="8"
                IsEnabled="{Binding CanInteract}"
                ToolTip="{Binding RoutingDescriptionText}">
          <UniformGrid Columns="2">
            <Button Content="手动"
                    ToolTip="手动切换"
                    Style="{StaticResource ManualRoutingButtonStyle}"
                    Click="ManualRouting_Click" />
            <Button Content="自动"
                    ToolTip="自动选择"
                    Style="{StaticResource AutomaticRoutingButtonStyle}"
                    Click="AutomaticRouting_Click" />
          </UniformGrid>
        </Border>
      </Grid>

      <Border Grid.Row="2"
              Margin="0,0,0,12"
              Style="{StaticResource SectionCard}">
        <StackPanel>
          <TextBlock Text="当前激活"
                     Margin="0,0,0,8"
                     Foreground="#605E5C"
                     FontSize="11"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />

          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="{Binding ActiveAccount.Title}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#1C1C1C"
                       TextTrimming="CharacterEllipsis" />
            <Border Margin="10,0,0,0"
                    Padding="7,2"
                    Background="#605E5C"
                    CornerRadius="8"
                    Visibility="{Binding ActiveAccount.HasProviderBadge, Converter={StaticResource BoolToVisibility}}">
              <TextBlock Text="{Binding ActiveAccount.ProviderBadge}"
                         Foreground="White"
                         FontSize="8"
                         FontWeight="SemiBold" />
            </Border>
            <Border Style="{StaticResource TierBadgeBorder}"
                    Margin="8,0,0,0"
                    Visibility="{Binding ActiveAccount.HasTierBadge, Converter={StaticResource BoolToVisibility}}">
              <TextBlock Text="{Binding ActiveAccount.TierBadgeText}"
                         Foreground="#1C1C1C"
                         FontSize="8"
                         FontWeight="SemiBold" />
            </Border>
            <Ellipse Width="8"
                     Height="8"
                     Margin="8,1,0,0"
                     VerticalAlignment="Center"
                     Fill="{Binding ActiveAccount.StatusBrush}"
                     ToolTip="{Binding ActiveAccount.StatusText}"
                     Visibility="{Binding ActiveAccount.HasSelection, Converter={StaticResource BoolToVisibility}}" />
          </StackPanel>

          <TextBlock Text="{Binding ActiveAccount.Subtitle}"
                     Margin="0,6,0,0"
                     Foreground="#605E5C"
                     FontSize="10"
                     Visibility="{Binding ActiveAccount.HasSubtitle, Converter={StaticResource BoolToVisibility}}"
                     TextWrapping="Wrap" />

          <StackPanel Margin="0,14,0,0"
                      Visibility="{Binding ActiveAccount.ShowQuotaBars, Converter={StaticResource BoolToVisibility}}">
            <Grid Margin="0,0,0,6">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="{Binding ActiveAccount.FiveHourQuotaLabel}"
                         Foreground="#605E5C"
                         FontSize="9" />
              <TextBlock Grid.Column="1"
                         Text="{Binding ActiveAccount.FiveHourAvailableText}"
                         Foreground="{Binding ActiveAccount.FiveHourProgressBrush}"
                         FontSize="9"
                         FontWeight="SemiBold" />
            </Grid>
            <Grid Height="6" Margin="0,0,0,12">
              <Border Background="#E9E9E9" CornerRadius="3" />
              <Border Background="{Binding ActiveAccount.FiveHourProgressBrush}"
                      CornerRadius="3"
                      HorizontalAlignment="Stretch"
                      RenderTransformOrigin="0,0.5">
                <Border.RenderTransform>
                  <ScaleTransform ScaleX="{Binding ActiveAccount.FiveHourUsedRatio}" />
                </Border.RenderTransform>
              </Border>
            </Grid>

            <Grid Margin="0,0,0,6">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="{Binding ActiveAccount.WeeklyQuotaLabel}"
                         Foreground="#605E5C"
                         FontSize="9" />
              <TextBlock Grid.Column="1"
                         Text="{Binding ActiveAccount.WeeklyAvailableText}"
                         Foreground="{Binding ActiveAccount.WeeklyProgressBrush}"
                         FontSize="9"
                         FontWeight="SemiBold" />
            </Grid>
            <Grid Height="6">
              <Border Background="#E9E9E9" CornerRadius="3" />
              <Border Background="{Binding ActiveAccount.WeeklyProgressBrush}"
                      CornerRadius="3"
                      HorizontalAlignment="Stretch"
                      RenderTransformOrigin="0,0.5">
                <Border.RenderTransform>
                  <ScaleTransform ScaleX="{Binding ActiveAccount.WeeklyUsedRatio}" />
                </Border.RenderTransform>
              </Border>
            </Grid>
          </StackPanel>

          <Grid Margin="0,14,0,0"
                Visibility="{Binding ActiveAccount.ShowTokenGrid, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel>
              <TextBlock Text="1 天"
                         Foreground="#605E5C"
                         FontSize="9"
                         HorizontalAlignment="Center" />
              <TextBlock Text="{Binding ActiveAccount.DailyTokens}"
                         Foreground="#1C1C1C"
                         FontSize="11"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="1">
              <TextBlock Text="1 周"
                         Foreground="#605E5C"
                         FontSize="9"
                         HorizontalAlignment="Center" />
              <TextBlock Text="{Binding ActiveAccount.WeeklyTokens}"
                         Foreground="#1C1C1C"
                         FontSize="11"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="2">
              <TextBlock Text="1 月"
                         Foreground="#605E5C"
                         FontSize="9"
                         HorizontalAlignment="Center" />
              <TextBlock Text="{Binding ActiveAccount.MonthlyTokens}"
                         Foreground="#1C1C1C"
                         FontSize="11"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Grid>

          <TextBlock Margin="0,14,0,0"
                     Text="{Binding LastRefreshText}"
                     Foreground="#605E5C"
                     FontSize="9"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Grid.Row="3"
              Margin="0,0,0,12"
              Padding="9,7"
              Background="White"
              BorderBrush="#11000000"
              BorderThickness="1"
              CornerRadius="8"
              Visibility="{Binding HasErrorText, Converter={StaticResource BoolToVisibility}}">
        <TextBlock Text="{Binding ErrorText}"
                   Foreground="#C42B1C"
                   FontSize="9"
                   TextWrapping="Wrap" />
      </Border>

      <Grid Grid.Row="4" Margin="0,0,0,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="{Binding Accounts.Count, StringFormat=账号与 Provider ({0})}"
                   Foreground="#605E5C"
                   FontSize="11"
                   VerticalAlignment="Center" />
        <TextBlock Grid.Column="1"
                   Text="{Binding ActivityText}"
                   Foreground="#0F6CBD"
                   FontSize="10"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding HasInlineActivityText, Converter={StaticResource BoolToVisibility}}"
                   TextTrimming="CharacterEllipsis" />
        <TextBlock Grid.Column="2"
                   Text="拖动排序"
                   Foreground="#605E5C"
                   FontSize="10"
                   VerticalAlignment="Center" />
      </Grid>

      <ListBox x:Name="AccountsList"
               Grid.Row="5"
               BorderThickness="0"
               Background="Transparent"
               ItemsSource="{Binding Accounts}"
               ScrollViewer.CanContentScroll="False"
               ScrollViewer.VerticalScrollBarVisibility="Auto"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled"
               ScrollViewer.PanningMode="VerticalOnly">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource AccountCardStyle}"
                    PreviewMouseLeftButtonDown="AccountCard_PreviewMouseLeftButtonDown">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.RowSpan="2"
                        Width="22"
                        Height="22"
                        Margin="0,0,9,0"
                        VerticalAlignment="Top"
                        Cursor="SizeAll"
                        PreviewMouseLeftButtonDown="DragHandle_PreviewMouseLeftButtonDown"
                        MouseMove="DragHandle_MouseMove">
                  <UniformGrid Columns="2" Rows="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="4" Height="4" Fill="#605E5C" Margin="1" />
                    <Ellipse Width="4" Height="4" Fill="#605E5C" Margin="1" />
                    <Ellipse Width="4" Height="4" Fill="#605E5C" Margin="1" />
                    <Ellipse Width="4" Height="4" Fill="#605E5C" Margin="1" />
                  </UniformGrid>
                </Border>

                <StackPanel x:Name="StandardCardContent"
                            Grid.Column="1">
                  <StackPanel.Style>
                    <Style TargetType="StackPanel">
                      <Setter Property="Visibility" Value="Visible" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.IsCompactCardDensity, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="True">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </StackPanel.Style>
                  <WrapPanel>
                    <TextBlock Text="{Binding Name}"
                               Margin="0,0,8,4"
                               Foreground="#1C1C1C"
                               FontSize="12"
                               FontWeight="SemiBold" />
                    <Border Margin="0,0,8,4"
                            Padding="7,2"
                            Background="#0067C0"
                            CornerRadius="8"
                            Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibility}}">
                      <TextBlock Text="当前激活"
                                 Foreground="White"
                                 FontSize="8"
                                 FontWeight="SemiBold" />
                    </Border>
                    <Border Margin="0,0,8,4"
                            Padding="7,2"
                            CornerRadius="8">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Background" Value="#605E5C" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOpenAi}" Value="False">
                              <Setter Property="Background" Value="#8764B8" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <TextBlock Text="{Binding ProviderBadge}"
                                 Foreground="White"
                                 FontSize="8"
                                 FontWeight="SemiBold" />
                    </Border>
                    <Border Style="{StaticResource TierBadgeBorder}"
                            Visibility="{Binding HasTierBadge, Converter={StaticResource BoolToVisibility}}">
                      <TextBlock Text="{Binding TierBadgeText}"
                                 Foreground="#1C1C1C"
                                 FontSize="8"
                                 FontWeight="SemiBold" />
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                      <Ellipse Width="8"
                               Height="8"
                               Margin="0,4,0,0"
                               Fill="{Binding StatusBrush}"
                               ToolTip="{Binding StatusText}" />
                    </StackPanel>
                  </WrapPanel>

                  <TextBlock Text="{Binding Subtitle}"
                             Foreground="#605E5C"
                             FontSize="10"
                             Visibility="{Binding HasSubtitle, Converter={StaticResource BoolToVisibility}}"
                             TextWrapping="Wrap"
                             TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Grid x:Name="CompactCardContent"
                      Grid.Column="1"
                      VerticalAlignment="Center">
                  <Grid.Style>
                    <Style TargetType="Grid">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.IsCompactCardDensity, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Grid.Style>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <TextBlock Text="{Binding Name}"
                             ToolTip="{Binding Name}"
                             Foreground="#1C1C1C"
                             FontSize="11"
                             FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis"
                             TextWrapping="NoWrap"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding CompactMetaText}"
                             ToolTip="{Binding CompactMetaText}"
                             Margin="8,0,0,0"
                             MaxWidth="92"
                             Foreground="#605E5C"
                             FontSize="9"
                             FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis"
                             TextWrapping="NoWrap"
                             VerticalAlignment="Center"
                             Visibility="{Binding HasCompactMetaText, Converter={StaticResource BoolToVisibility}}" />
                  <Ellipse Grid.Column="2"
                           Width="8"
                           Height="8"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Fill="{Binding StatusBrush}"
                           ToolTip="{Binding StatusText}" />
                </Grid>

                <StackPanel x:Name="StandardActionButtons"
                            Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                  <StackPanel.Style>
                    <Style TargetType="StackPanel">
                      <Setter Property="Visibility" Value="Visible" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.IsCompactCardDensity, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="True">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </StackPanel.Style>
                  <Button Content="切换"
                          Style="{StaticResource MiniSecondaryButton}"
                          Visibility="{Binding CanActivate, Converter={StaticResource BoolToVisibility}}"
                          Click="UseAccount_Click" />
                  <Button Content="启动"
                          Style="{StaticResource MiniPrimaryButton}"
                          Visibility="{Binding CanLaunch, Converter={StaticResource BoolToVisibility}}"
                          Click="LaunchAccount_Click" />
                  <Button Content="&#xE72C;"
                          Style="{StaticResource IconActionButton}"
                          Visibility="{Binding CanRefreshOfficialQuota, Converter={StaticResource BoolToVisibility}}"
                          ToolTip="刷新官方额度"
                          Click="RefreshOfficialQuota_Click" />
                  <Button Content="&#xE783;"
                          Style="{StaticResource IconActionButton}"
                          Visibility="{Binding CanProbe, Converter={StaticResource BoolToVisibility}}"
                          ToolTip="探测 API"
                          Click="ProbeAccount_Click" />
                  <Button Content="&#xE70F;"
                          Style="{StaticResource IconActionButton}"
                          ToolTip="编辑账号"
                          Click="EditAccount_Click" />
                  <Button Content="&#xE74D;"
                          Style="{StaticResource IconActionButton}"
                          ToolTip="删除账号"
                          Click="DeleteAccount_Click" />
                </StackPanel>

                <StackPanel x:Name="CompactActionButtons"
                            Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                  <StackPanel.Style>
                    <Style TargetType="StackPanel">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.IsCompactCardDensity, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </StackPanel.Style>
                  <Button Content="&#xE8AB;"
                          Style="{StaticResource IconActionButton}"
                          Visibility="{Binding CanActivate, Converter={StaticResource BoolToVisibility}}"
                          ToolTip="切换账号"
                          Click="UseAccount_Click" />
                  <Button Content="&#xE768;"
                          Style="{StaticResource IconActionButton}"
                          Visibility="{Binding CanLaunch, Converter={StaticResource BoolToVisibility}}"
                          ToolTip="启动 Codex"
                          Click="LaunchAccount_Click" />
                  <Button Content="&#xE72C;"
                          Style="{StaticResource IconActionButton}"
                          Visibility="{Binding CanRefreshOfficialQuota, Converter={StaticResource BoolToVisibility}}"
                          ToolTip="刷新官方额度"
                          Click="RefreshOfficialQuota_Click" />
                  <Button Content="&#xE783;"
                          Style="{StaticResource IconActionButton}"
                          Visibility="{Binding CanProbe, Converter={StaticResource BoolToVisibility}}"
                          ToolTip="探测 API"
                          Click="ProbeAccount_Click" />
                  <Button Content="&#xE70F;"
                          Style="{StaticResource IconActionButton}"
                          ToolTip="编辑账号"
                          Click="EditAccount_Click" />
                  <Button Content="&#xE74D;"
                          Style="{StaticResource IconActionButton}"
                          ToolTip="删除账号"
                          Click="DeleteAccount_Click" />
                </StackPanel>

                <StackPanel x:Name="StandardQuotaRows"
                            Grid.Row="2"
                            Grid.Column="1"
                            Grid.ColumnSpan="2"
                            Margin="0,12,0,0">
                  <StackPanel.Style>
                    <Style TargetType="StackPanel">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowQuotaBars}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DataContext.IsCompactCardDensity, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="True">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </StackPanel.Style>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding FiveHourQuotaLabel}"
                               Foreground="#605E5C"
                               FontSize="9" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding FiveHourAvailableText}"
                               Foreground="{Binding FiveHourProgressBrush}"
                               FontSize="9"
                               FontWeight="SemiBold" />
                  </Grid>
                  <Grid Height="6" Margin="0,0,0,12">
                    <Border Background="#E9E9E9" CornerRadius="3" />
                    <Border Background="{Binding FiveHourProgressBrush}"
                            CornerRadius="3"
                            HorizontalAlignment="Stretch"
                            RenderTransformOrigin="0,0.5">
                      <Border.RenderTransform>
                        <ScaleTransform ScaleX="{Binding FiveHourUsedRatio}" />
                      </Border.RenderTransform>
                    </Border>
                  </Grid>

                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding WeeklyQuotaLabel}"
                               Foreground="#605E5C"
                               FontSize="9" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding WeeklyAvailableText}"
                               Foreground="{Binding WeeklyProgressBrush}"
                               FontSize="9"
                               FontWeight="SemiBold" />
                  </Grid>
                  <Grid Height="6">
                    <Border Background="#E9E9E9" CornerRadius="3" />
                    <Border Background="{Binding WeeklyProgressBrush}"
                            CornerRadius="3"
                            HorizontalAlignment="Stretch"
                            RenderTransformOrigin="0,0.5">
                      <Border.RenderTransform>
                        <ScaleTransform ScaleX="{Binding WeeklyUsedRatio}" />
                      </Border.RenderTransform>
                    </Border>
                  </Grid>
                </StackPanel>

                <StackPanel x:Name="CompactQuotaRows"
                            Grid.Row="2"
                            Grid.Column="1"
                            Grid.ColumnSpan="2"
                            Margin="0,7,0,0">
                  <StackPanel.Style>
                    <Style TargetType="StackPanel">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowQuotaBars}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DataContext.IsCompactCardDensity, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="False">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </StackPanel.Style>
                  <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="58" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="62" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding FiveHourQuotaInlineLabel}"
                               Foreground="#605E5C"
                               FontSize="8.5" />
                    <Grid Grid.Column="1"
                          Height="5"
                          Margin="7,0"
                          VerticalAlignment="Center">
                      <Border Background="#E9E9E9" CornerRadius="3" />
                      <Border Background="{Binding FiveHourProgressBrush}"
                              CornerRadius="3"
                              HorizontalAlignment="Stretch"
                              RenderTransformOrigin="0,0.5">
                        <Border.RenderTransform>
                          <ScaleTransform ScaleX="{Binding FiveHourUsedRatio}" />
                        </Border.RenderTransform>
                      </Border>
                    </Grid>
                    <TextBlock Grid.Column="2"
                               Text="{Binding FiveHourAvailableText}"
                               Foreground="{Binding FiveHourProgressBrush}"
                               FontSize="8.5"
                               FontWeight="SemiBold" />
                  </Grid>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="58" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="62" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding WeeklyQuotaInlineLabel}"
                               Foreground="#605E5C"
                               FontSize="8.5" />
                    <Grid Grid.Column="1"
                          Height="5"
                          Margin="7,0"
                          VerticalAlignment="Center">
                      <Border Background="#E9E9E9" CornerRadius="3" />
                      <Border Background="{Binding WeeklyProgressBrush}"
                              CornerRadius="3"
                              HorizontalAlignment="Stretch"
                              RenderTransformOrigin="0,0.5">
                        <Border.RenderTransform>
                          <ScaleTransform ScaleX="{Binding WeeklyUsedRatio}" />
                        </Border.RenderTransform>
                      </Border>
                    </Grid>
                    <TextBlock Grid.Column="2"
                               Text="{Binding WeeklyAvailableText}"
                               Foreground="{Binding WeeklyProgressBrush}"
                               FontSize="8.5"
                               FontWeight="SemiBold" />
                  </Grid>
                </StackPanel>

                <Grid Grid.Row="2"
                      Grid.Column="1"
                      Grid.ColumnSpan="2"
                      Margin="0,12,0,0">
                  <Grid.Style>
                    <Style TargetType="Grid">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowTokenGrid}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DataContext.IsCompactCardDensity, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="True">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Grid.Style>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>

                  <StackPanel>
                    <TextBlock Text="1 天"
                               Foreground="#605E5C"
                               FontSize="9"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding DailyTokens}"
                               Foreground="#1C1C1C"
                               FontSize="11"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                  </StackPanel>

                  <StackPanel Grid.Column="1">
                    <TextBlock Text="1 周"
                               Foreground="#605E5C"
                               FontSize="9"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding WeeklyTokens}"
                               Foreground="#1C1C1C"
                               FontSize="11"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                  </StackPanel>

                  <StackPanel Grid.Column="2">
                    <TextBlock Text="1 月"
                               Foreground="#605E5C"
                               FontSize="9"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding MonthlyTokens}"
                               Foreground="#1C1C1C"
                               FontSize="11"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                  </StackPanel>
                </Grid>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <Canvas x:Name="DragPreviewLayer"
              Grid.RowSpan="7"
              Panel.ZIndex="20"
              IsHitTestVisible="False"
              Visibility="Collapsed">
        <Border x:Name="DragPreviewCard"
                Width="320"
                Padding="11"
                Background="#99FFFFFF"
                BorderBrush="#330067C0"
                BorderThickness="1"
                CornerRadius="8"
                Opacity="0.48">
          <StackPanel>
            <WrapPanel>
              <TextBlock x:Name="DragPreviewNameText"
                         Margin="0,0,8,4"
                         Foreground="#1C1C1C"
                         FontSize="12"
                         FontWeight="SemiBold" />
              <Border x:Name="DragPreviewProviderBadge"
                      Margin="0,0,8,4"
                      Padding="7,2"
                      Background="#605E5C"
                      CornerRadius="8">
                <TextBlock x:Name="DragPreviewProviderText"
                           Foreground="White"
                           FontSize="8"
                           FontWeight="SemiBold" />
              </Border>
              <Border x:Name="DragPreviewTierBadge"
                      Margin="0,0,8,4"
                      Padding="7,2"
                      Background="#F3F3F3"
                      BorderBrush="#D9D9D9"
                      BorderThickness="1"
                      CornerRadius="8"
                      Visibility="Collapsed">
                <TextBlock x:Name="DragPreviewTierText"
                           Foreground="#1C1C1C"
                           FontSize="8"
                           FontWeight="SemiBold" />
              </Border>
              <Ellipse x:Name="DragPreviewStatusDot"
                       Width="8"
                       Height="8"
                       Margin="0,4,0,0"
                       Fill="#9E9E9E" />
            </WrapPanel>
            <TextBlock x:Name="DragPreviewSubtitleText"
                       Foreground="#605E5C"
                       FontSize="10"
                       TextWrapping="Wrap"
                       TextTrimming="CharacterEllipsis" />
          </StackPanel>
        </Border>
      </Canvas>
    </Grid>
  </Border>
</Window>
