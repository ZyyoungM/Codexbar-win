<Window x:Class="CodexBar.Win.FlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CodexBar"
        Width="460"
        Height="540"
        MinWidth="440"
        MinHeight="360"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Topmost="False">
  <Border Padding="14" Background="#FAFAFA">
    <DockPanel LastChildFill="True">
      <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0" IsEnabled="{Binding CanInteract}">
        <Button Content="&#x767B;&#x5F55; OpenAI" Width="90" Margin="0,0,6,0" Click="OAuth_Click" />
        <Button Content="&#x6DFB;&#x52A0;&#x517C;&#x5BB9; Provider" Width="132" Margin="0,0,6,0" Click="AddCompatible_Click" />
        <Button Content="&#x8BBE;&#x7F6E;" Width="58" Margin="0,0,6,0" Click="Settings_Click" />
        <Button Content="&#x9000;&#x51FA;" Width="58" Click="Quit_Click" />
      </StackPanel>
      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <TextBlock Text="CodexBar" FontWeight="Bold" FontSize="18" />
          <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Margin="0,6,0,8" />
          <TextBlock Text="{Binding ActivityText}" Foreground="#0F5AA6" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,8" />
          <TextBlock Text="{Binding UsageText}" TextWrapping="Wrap" Margin="0,0,0,12" />
          <TextBlock Text="{Binding LastRefreshText}" Foreground="#666666" TextWrapping="Wrap" Margin="0,0,0,8" />
          <TextBlock Text="{Binding QuotaStatusText}" Foreground="#8A5A00" TextWrapping="Wrap" Margin="0,0,0,8" />
          <TextBlock Text="{Binding ErrorText}" Foreground="#B00020" TextWrapping="Wrap" Margin="0,0,0,8" />
          <Button Content="&#x5237;&#x65B0;" Width="90" HorizontalAlignment="Left" Click="Refresh_Click" IsEnabled="{Binding CanInteract}" />
          <TextBlock Text="&#x8D26;&#x53F7;&#x4E0E; Provider" FontWeight="SemiBold" Margin="0,16,0,6" />
          <ListBox x:Name="AccountsList" ItemsSource="{Binding Accounts}" DisplayMemberPath="Display" MinHeight="180" Height="260" IsEnabled="{Binding CanInteract}" />
          <WrapPanel Margin="0,8,0,0" IsEnabled="{Binding CanInteract}">
            <Button Content="&#x4F7F;&#x7528;" Width="58" Margin="0,0,8,8" Click="UseSelected_Click" />
            <Button Content="&#x542F;&#x52A8; Codex" Width="96" Margin="0,0,8,8" Click="LaunchCodex_Click" />
            <Button Content="&#x7F16;&#x8F91;" Width="58" Margin="0,0,8,8" Click="EditSelected_Click" />
            <Button Content="&#x4E0A;&#x79FB;" Width="52" Margin="0,0,8,8" Click="MoveUp_Click" />
            <Button Content="&#x4E0B;&#x79FB;" Width="52" Margin="0,0,8,8" Click="MoveDown_Click" />
            <Button Content="&#x5220;&#x9664;" Width="62" Margin="0,0,0,8" Click="DeleteSelected_Click" />
          </WrapPanel>
        </StackPanel>
      </ScrollViewer>
    </DockPanel>
  </Border>
</Window>
