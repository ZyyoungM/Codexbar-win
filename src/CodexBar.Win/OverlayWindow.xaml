<Window x:Class="CodexBar.Win.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CodexBar Overlay"
        Width="236"
        MinWidth="236"
        MaxWidth="272"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        FontFamily="Microsoft YaHei UI"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

    <Style x:Key="OverlayIconButton" TargetType="Button">
      <Setter Property="Width" Value="20" />
      <Setter Property="Height" Value="20" />
      <Setter Property="Margin" Value="4,0,0,0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#99FFFFFF" />
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#18FFFFFF" />
                <Setter Property="Foreground" Value="#FFFFFFFF" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.35" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="OverlayTextButton" TargetType="Button">
      <Setter Property="MinWidth" Value="32" />
      <Setter Property="Height" Value="20" />
      <Setter Property="Margin" Value="4,0,0,0" />
      <Setter Property="Padding" Value="6,0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="#12FFFFFF" />
      <Setter Property="Foreground" Value="#D9FFFFFF" />
      <Setter Property="FontSize" Value="8" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#24FFFFFF" />
                <Setter Property="Foreground" Value="#FFFFFFFF" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.35" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border Padding="2"
          CornerRadius="10"
          Background="#D9202020"
          BorderBrush="#14FFFFFF"
          BorderThickness="1"
          PreviewMouseLeftButtonDown="OverlaySurface_PreviewMouseLeftButtonDown">
    <Border Padding="10"
            CornerRadius="8"
            Background="#E3202020">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Orientation="Horizontal"
                      VerticalAlignment="Center">
            <Ellipse Width="4"
                     Height="4"
                     Margin="0,0,5,0"
                     Fill="#60CDFF" />
            <TextBlock Text="CodexBar"
                       Foreground="#66FFFFFF"
                       FontSize="8"
                       VerticalAlignment="Center" />
            <Border Margin="7,0,0,0"
                    Padding="5,1"
                    Background="#18FFFFFF"
                    CornerRadius="6"
                    Visibility="{Binding ActiveAccount.HasProviderBadge, Converter={StaticResource BoolToVisibility}}">
              <TextBlock Text="{Binding ActiveAccount.ProviderBadge}"
                         Foreground="#D9FFFFFF"
                         FontSize="8"
                         FontWeight="SemiBold" />
            </Border>
          </StackPanel>

          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right">
            <Button x:Name="OpacityButton"
                    Content="88%"
                    Style="{StaticResource OverlayTextButton}"
                    ToolTip="调整透明度"
                    Click="Opacity_Click" />
            <Button Content="&#xE70D;"
                    Style="{StaticResource OverlayIconButton}"
                    ToolTip="关闭"
                    Click="Close_Click" />
          </StackPanel>
        </Grid>

        <StackPanel>
          <WrapPanel>
            <TextBlock Text="{Binding ActiveAccount.Title}"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,6,3" />
            <Border Padding="5,1"
                    Background="#2AFFFFFF"
                    CornerRadius="6"
                    Visibility="{Binding ActiveAccount.HasTierBadge, Converter={StaticResource BoolToVisibility}}"
                    Margin="0,1,6,0">
              <TextBlock Text="{Binding ActiveAccount.TierBadgeText}"
                         Foreground="#F3F3F3"
                         FontSize="8"
                         FontWeight="SemiBold" />
            </Border>
            <Ellipse Width="7"
                     Height="7"
                     Margin="0,5,0,0"
                     Fill="{Binding ActiveAccount.StatusBrush}"
                     Visibility="{Binding ActiveAccount.HasSelection, Converter={StaticResource BoolToVisibility}}" />
          </WrapPanel>

          <TextBlock Text="{Binding ActiveAccount.Subtitle}"
                     Foreground="#A6FFFFFF"
                     FontSize="9"
                     TextWrapping="Wrap"
                     TextTrimming="CharacterEllipsis"
                     Visibility="{Binding HasActiveAccount, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>

        <StackPanel Margin="0,8,0,0"
                    Visibility="{Binding ActiveAccount.ShowQuotaBars, Converter={StaticResource BoolToVisibility}}">
          <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="5h 额度"
                       Foreground="#77FFFFFF"
                       FontSize="8" />
            <TextBlock Grid.Column="1"
                       Text="{Binding ActiveAccount.FiveHourAvailableText}"
                       Foreground="{Binding ActiveAccount.FiveHourProgressBrush}"
                       FontSize="8"
                       FontWeight="SemiBold" />
          </Grid>
          <Grid Height="4" Margin="0,0,0,8">
            <Border Background="#14FFFFFF" CornerRadius="2" />
            <Border Background="{Binding ActiveAccount.FiveHourProgressBrush}"
                    CornerRadius="2"
                    HorizontalAlignment="Stretch"
                    RenderTransformOrigin="0,0.5">
              <Border.RenderTransform>
                <ScaleTransform ScaleX="{Binding ActiveAccount.FiveHourUsedRatio}" />
              </Border.RenderTransform>
            </Border>
          </Grid>

          <Grid x:Name="WeeklyQuotaRow"
                Margin="0,0,0,4"
                Visibility="Collapsed">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="周额度"
                       Foreground="#77FFFFFF"
                       FontSize="8" />
            <TextBlock Grid.Column="1"
                       Text="{Binding ActiveAccount.WeeklyAvailableText}"
                       Foreground="{Binding ActiveAccount.WeeklyProgressBrush}"
                       FontSize="8"
                       FontWeight="SemiBold" />
          </Grid>
          <Grid x:Name="WeeklyQuotaBar"
                Height="4"
                Visibility="Collapsed">
            <Border Background="#14FFFFFF" CornerRadius="2" />
            <Border Background="{Binding ActiveAccount.WeeklyProgressBrush}"
                    CornerRadius="2"
                    HorizontalAlignment="Stretch"
                    RenderTransformOrigin="0,0.5">
              <Border.RenderTransform>
                <ScaleTransform ScaleX="{Binding ActiveAccount.WeeklyUsedRatio}" />
              </Border.RenderTransform>
            </Border>
          </Grid>
        </StackPanel>

        <Border Margin="0,8,0,0"
                Padding="8"
                Background="#12FFFFFF"
                BorderBrush="#12FFFFFF"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{Binding ActiveAccount.ShowTokenGrid, Converter={StaticResource BoolToVisibility}}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel>
              <TextBlock Text="今日"
                         Foreground="#66FFFFFF"
                         FontSize="8"
                         HorizontalAlignment="Center" />
              <TextBlock Text="{Binding ActiveAccount.DailyTokens}"
                         Foreground="#F3F3F3"
                         FontSize="9"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="1">
              <TextBlock Text="7天"
                         Foreground="#66FFFFFF"
                         FontSize="8"
                         HorizontalAlignment="Center" />
              <TextBlock Text="{Binding ActiveAccount.WeeklyTokens}"
                         Foreground="#F3F3F3"
                         FontSize="9"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="2">
              <TextBlock Text="30天"
                         Foreground="#66FFFFFF"
                         FontSize="8"
                         HorizontalAlignment="Center" />
              <TextBlock Text="{Binding ActiveAccount.MonthlyTokens}"
                         Foreground="#F3F3F3"
                         FontSize="9"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Grid>
        </Border>

        <StackPanel x:Name="ExpandedPanel"
                    Visibility="Collapsed"
                    Margin="0,8,0,0">
          <Border Padding="8"
                  Background="#12FFFFFF"
                  BorderBrush="#12FFFFFF"
                  BorderThickness="1"
                  CornerRadius="8">
            <StackPanel>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="模式"
                           Foreground="#66FFFFFF"
                           FontSize="8" />
                <TextBlock Grid.Column="1"
                           Text="{Binding RoutingModeBadgeText}"
                           Foreground="#E8F3FF"
                           FontSize="8"
                           HorizontalAlignment="Right" />
              </Grid>
              <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="今日"
                           Foreground="#66FFFFFF"
                           FontSize="8" />
                <TextBlock Grid.Column="1"
                           Text="{Binding ActiveAccount.DailyTokens, StringFormat={}{0} tokens}"
                           Foreground="#F3F3F3"
                           FontSize="8"
                           HorizontalAlignment="Right" />
              </Grid>
              <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="7天"
                           Foreground="#66FFFFFF"
                           FontSize="8" />
                <TextBlock Grid.Column="1"
                           Text="{Binding ActiveAccount.WeeklyTokens, StringFormat={}{0} tokens}"
                           Foreground="#F3F3F3"
                           FontSize="8"
                           HorizontalAlignment="Right" />
              </Grid>
              <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="30天"
                           Foreground="#66FFFFFF"
                           FontSize="8" />
                <TextBlock Grid.Column="1"
                           Text="{Binding ActiveAccount.MonthlyTokens, StringFormat={}{0} tokens}"
                           Foreground="#F3F3F3"
                           FontSize="8"
                           HorizontalAlignment="Right" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Margin="0,8,0,0"
                  Padding="8"
                  Background="#10FFFFFF"
                  BorderBrush="#10FFFFFF"
                  BorderThickness="1"
                  CornerRadius="8"
                  Visibility="{Binding HasFeedbackText, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
              <TextBlock Text="{Binding ActivityText}"
                         Foreground="#D9EEFF"
                         FontSize="8"
                         TextWrapping="Wrap"
                         Visibility="{Binding HasActivityText, Converter={StaticResource BoolToVisibility}}" />
              <TextBlock Margin="0,4,0,0"
                         Text="{Binding ErrorText}"
                         Foreground="#FFB9B9"
                         FontSize="8"
                         TextWrapping="Wrap"
                         Visibility="{Binding HasErrorText, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>
          </Border>
        </StackPanel>

        <Grid Margin="0,8,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <TextBlock VerticalAlignment="Center"
                     Foreground="#59FFFFFF"
                     FontSize="7.5"
                     Text="{Binding LastRefreshText}" />

          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right">
            <Button Content="主窗"
                    Style="{StaticResource OverlayTextButton}"
                    ToolTip="打开主浮窗"
                    Click="ShowFlyout_Click" />
            <Button Content="&#xE72C;"
                    Style="{StaticResource OverlayIconButton}"
                    ToolTip="刷新"
                    Click="Refresh_Click" />
            <Button Content="&#xE898;"
                    Style="{StaticResource OverlayIconButton}"
                    ToolTip="启动 Codex"
                    Click="Launch_Click"
                    IsEnabled="{Binding HasActiveAccount}" />
            <Button x:Name="ExpandButton"
                    Content="&#xE70D;"
                    Style="{StaticResource OverlayIconButton}"
                    ToolTip="展开"
                    Click="ToggleExpanded_Click" />
          </StackPanel>
        </Grid>
      </StackPanel>
    </Border>
  </Border>
</Window>
