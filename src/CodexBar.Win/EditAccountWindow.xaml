<Window x:Class="CodexBar.Win.EditAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑账号"
        Width="680"
        Height="700"
        MinWidth="540"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="#FFF5F5F5"
        FontFamily="Microsoft YaHei UI"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
  <Window.Resources>
    <Style x:Key="SectionCard" TargetType="Border">
      <Setter Property="Padding" Value="14" />
      <Setter Property="Margin" Value="0,0,0,12" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#11000000" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#1C1C1C" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#605E5C" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="InputTextBox" TargetType="TextBox">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="BorderBrush" Value="#D9D9D9" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="#1C1C1C" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style TargetType="PasswordBox">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="BorderBrush" Value="#D9D9D9" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="#1C1C1C" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="ReadOnlyTextBox" TargetType="TextBox" BasedOn="{StaticResource InputTextBox}">
      <Setter Property="IsReadOnly" Value="True" />
      <Setter Property="Background" Value="#F7F7F7" />
    </Style>

    <Style x:Key="ActionButton" TargetType="Button">
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#1C1C1C" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#D9D9D9" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="#0067C0" />
      <Setter Property="BorderBrush" Value="#0067C0" />
    </Style>

    <Style x:Key="SubtleButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
      <Setter Property="Background" Value="#FFF5F5F5" />
      <Setter Property="BorderBrush" Value="#FFF5F5F5" />
      <Setter Property="FontWeight" Value="Normal" />
    </Style>
  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Style="{StaticResource SectionCard}"
            Background="#F7FAFF"
            BorderBrush="#CFE4F9">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock Text="编辑账号"
                     Foreground="#1C1C1C"
                     FontSize="17"
                     FontWeight="SemiBold" />
          <TextBlock Margin="0,6,0,0"
                     Text="只会更新当前账号的展示信息与激活配置，不会重写历史 sessions / archived_sessions。"
                     Foreground="#605E5C"
                     FontSize="11"
                     TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Column="1"
                Margin="12,0,0,0"
                Padding="8,3"
                Background="#E7F1FB"
                CornerRadius="8"
                VerticalAlignment="Top">
          <TextBlock x:Name="AccountKindBadgeText"
                     Text="账号"
                     Foreground="#0067C0"
                     FontSize="10"
                     FontWeight="SemiBold" />
        </Border>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel>
        <Border Style="{StaticResource SectionCard}">
          <StackPanel>
            <TextBlock Text="基础信息" Style="{StaticResource SectionTitle}" />

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="0">
                <TextBlock Text="Provider ID" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="ProviderIdBox" Style="{StaticResource InputTextBox}" />
              </StackPanel>

              <StackPanel Grid.Column="2">
                <TextBlock Text="账号 ID" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="AccountIdBox" Style="{StaticResource ReadOnlyTextBox}" />
              </StackPanel>
            </Grid>

            <Grid Margin="0,14,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="0">
                <TextBlock Text="账号显示名" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="AccountLabelBox" Style="{StaticResource InputTextBox}" />
              </StackPanel>

              <StackPanel Grid.Column="2">
                <TextBlock Text="Provider 名称" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="ProviderNameBox" Style="{StaticResource InputTextBox}" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <Border x:Name="CompatiblePanel" Style="{StaticResource SectionCard}">
          <StackPanel>
            <TextBlock Text="兼容 Provider 配置" Style="{StaticResource SectionTitle}" />

            <TextBlock x:Name="BaseUrlLabel" Text="Base URL" Style="{StaticResource FieldLabel}" />
            <TextBox x:Name="BaseUrlBox" Style="{StaticResource InputTextBox}" />

            <TextBlock Margin="0,14,0,0" Text="新 API Key（留空则保留当前值）" Style="{StaticResource FieldLabel}" />
            <PasswordBox x:Name="ApiKeyBox" />

            <Expander x:Name="AdvancedCompatExpander"
                      Header="高级兼容选项"
                      IsExpanded="False"
                      Margin="0,14,0,0">
              <StackPanel Margin="0,10,0,0">
                <TextBlock Text="Codex Provider ID（可选）" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="CodexProviderIdBox" Style="{StaticResource InputTextBox}" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="#8A8886"
                           FontSize="10"
                           Text="大多数兼容 OpenAI 的 Provider 保持默认 openai 即可，仅在需要兼容特定 provider 过滤时再修改。" />
              </StackPanel>
            </Expander>
          </StackPanel>
        </Border>

        <Border x:Name="OfficialUsagePanel"
                Style="{StaticResource SectionCard}"
                Visibility="Collapsed">
          <StackPanel>
            <TextBlock Text="OpenAI 官方额度快照" Style="{StaticResource SectionTitle}" />

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="0">
                <TextBlock Text="官方套餐" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="OfficialPlanBox" Style="{StaticResource ReadOnlyTextBox}" />
              </StackPanel>

              <StackPanel Grid.Column="2">
                <TextBlock Text="5 小时额度" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="FiveHourQuotaBox" Style="{StaticResource ReadOnlyTextBox}" />
              </StackPanel>
            </Grid>

            <TextBlock Margin="0,14,0,0" Text="周额度" Style="{StaticResource FieldLabel}" />
            <TextBox x:Name="WeeklyQuotaBox" Style="{StaticResource ReadOnlyTextBox}" />

            <TextBlock Margin="0,14,0,0" Text="获取状态" Style="{StaticResource FieldLabel}" />
            <TextBox x:Name="OfficialStatusBox"
                     Style="{StaticResource ReadOnlyTextBox}"
                     MinHeight="84"
                     TextWrapping="Wrap"
                     AcceptsReturn="True" />
          </StackPanel>
        </Border>

        <Border x:Name="StatusPanel"
                Style="{StaticResource SectionCard}"
                Margin="0,0,0,0"
                Background="#F7FAFF"
                BorderBrush="#CFE4F9"
                Visibility="Collapsed">
          <StackPanel>
            <TextBlock x:Name="StatusTitleText"
                       Foreground="#0F6CBD"
                       FontSize="12"
                       FontWeight="SemiBold" />
            <TextBlock x:Name="StatusBodyText"
                       Margin="0,6,0,0"
                       Foreground="#605E5C"
                       FontSize="11"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2"
            Margin="0,12,0,0"
            Padding="12"
            Background="White"
            BorderBrush="#11000000"
            BorderThickness="1"
            CornerRadius="8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock VerticalAlignment="Center"
                   Foreground="#605E5C"
                   FontSize="10"
                   Text="账号编辑只影响之后的新激活，不会回写历史会话。" />

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
          <Button Content="取消"
                  Width="78"
                  Margin="0,0,8,0"
                  Style="{StaticResource SubtleButton}"
                  Click="Cancel_Click" />
          <Button x:Name="ProbeButton"
                  Content="测试连接"
                  Width="92"
                  Margin="0,0,8,0"
                  Style="{StaticResource ActionButton}"
                  Click="Probe_Click" />
          <Button x:Name="SaveButton"
                  Content="保存"
                  Width="78"
                  Style="{StaticResource PrimaryButton}"
                  Click="Save_Click" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
