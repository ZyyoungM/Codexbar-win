<Window x:Class="CodexBar.Win.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CodexBar 设置"
        Width="860"
        Height="760"
        MinWidth="680"
        MinHeight="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="#FFF5F5F5"
        FontFamily="Microsoft YaHei UI"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
  <Window.Resources>
    <Style x:Key="SectionCard" TargetType="Border">
      <Setter Property="Padding" Value="14" />
      <Setter Property="Margin" Value="0,0,0,12" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#11000000" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#1C1C1C" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#605E5C" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="InputTextBox" TargetType="TextBox">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="BorderBrush" Value="#D9D9D9" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="#1C1C1C" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="InputComboBox" TargetType="ComboBox">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="BorderBrush" Value="#D9D9D9" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="#1C1C1C" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="ActionButton" TargetType="Button">
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#1C1C1C" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#D9D9D9" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="#0067C0" />
      <Setter Property="BorderBrush" Value="#0067C0" />
    </Style>

    <Style x:Key="SubtleButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
      <Setter Property="Background" Value="#FFF5F5F5" />
      <Setter Property="BorderBrush" Value="#FFF5F5F5" />
      <Setter Property="FontWeight" Value="Normal" />
    </Style>

    <Style x:Key="InfoText" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#605E5C" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Style="{StaticResource SectionCard}"
            Background="#F7FAFF"
            BorderBrush="#CFE4F9">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock Text="设置"
                     Foreground="#1C1C1C"
                     FontSize="17"
                     FontWeight="SemiBold" />
          <TextBlock Margin="0,6,0,0"
                     Text="这些设置只影响 CodexBar 的本地行为与新会话激活流程。真正写入 Codex 当前激活态的仍然只有 config.toml 和 auth.json。"
                     Foreground="#605E5C"
                     FontSize="11"
                     TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Top">
          <Border Margin="10,0,0,0"
                  Padding="8,3"
                  Background="#E7F1FB"
                  CornerRadius="8">
            <TextBlock Text="本地设置"
                       Foreground="#0067C0"
                       FontSize="10"
                       FontWeight="SemiBold" />
          </Border>
          <Border Margin="8,0,0,0"
                  Padding="8,3"
                  Background="#F3F3F3"
                  CornerRadius="8">
            <TextBlock Text="不改历史会话"
                       Foreground="#605E5C"
                       FontSize="10"
                       FontWeight="SemiBold" />
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel>
        <Border Style="{StaticResource SectionCard}">
          <StackPanel>
            <TextBlock Text="运行路径与检测" Style="{StaticResource SectionTitle}" />

            <Border Padding="10"
                    Background="#F7F7F7"
                    BorderBrush="#11000000"
                    BorderThickness="1"
                    CornerRadius="8">
              <TextBlock x:Name="PathsText" Style="{StaticResource InfoText}" />
            </Border>

            <Grid Margin="0,12,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0">
                <TextBlock Text="Codex Desktop 路径" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="CodexDesktopPathBox" Style="{StaticResource InputTextBox}" />
              </StackPanel>
              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          VerticalAlignment="Bottom"
                          Margin="10,0,0,0">
                <Button Content="浏览"
                        Width="74"
                        Margin="0,0,8,0"
                        Style="{StaticResource ActionButton}"
                        Click="BrowseDesktop_Click" />
                <Button Content="探测"
                        Width="74"
                        Style="{StaticResource ActionButton}"
                        Click="DetectDesktop_Click" />
              </StackPanel>
            </Grid>

            <Grid Margin="0,12,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0">
                <TextBlock Text="Codex CLI 路径" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="CodexCliPathBox" Style="{StaticResource InputTextBox}" />
              </StackPanel>
              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          VerticalAlignment="Bottom"
                          Margin="10,0,0,0">
                <Button Content="浏览"
                        Width="74"
                        Margin="0,0,8,0"
                        Style="{StaticResource ActionButton}"
                        Click="BrowseCli_Click" />
                <Button Content="探测"
                        Width="74"
                        Style="{StaticResource ActionButton}"
                        Click="DetectCli_Click" />
              </StackPanel>
            </Grid>

            <Border Margin="0,12,0,0"
                    Padding="10"
                    Background="#FAFBFE"
                    BorderBrush="#D7E7F8"
                    BorderThickness="1"
                    CornerRadius="8">
              <TextBlock x:Name="DetectionText"
                         Style="{StaticResource InfoText}"
                         Text="可在这里查看路径探测结果。" />
            </Border>

            <StackPanel Margin="0,12,0,0"
                        Orientation="Horizontal">
              <Button Content="测试启动 Codex"
                      Width="128"
                      Style="{StaticResource PrimaryButton}"
                      Click="LaunchCodex_Click" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCard}">
          <StackPanel>
            <TextBlock Text="行为与排序" Style="{StaticResource SectionTitle}" />

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="0">
                <TextBlock Text="账号排序方式" Style="{StaticResource FieldLabel}" />
                <ComboBox x:Name="AccountSortModeBox"
                          Width="240"
                          HorizontalAlignment="Left"
                          Style="{StaticResource InputComboBox}" />
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource InfoText}"
                           Text="手动排序支持拖动卡片；按用量排序会优先考虑额度和最近使用情况。" />
              </StackPanel>

              <StackPanel Grid.Column="2">
                <TextBlock Text="激活后行为" Style="{StaticResource FieldLabel}" />
                <ComboBox x:Name="ActivationBehaviorBox"
                          Width="240"
                          HorizontalAlignment="Left"
                          Style="{StaticResource InputComboBox}" />
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource InfoText}"
                           Text="选择仅改配置，或在切换完成后直接启动新的 Codex。" />
              </StackPanel>
            </Grid>

            <Grid Margin="0,14,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="0">
                <TextBlock Text="OpenAI 账号模式" Style="{StaticResource FieldLabel}" />
                <ComboBox x:Name="OpenAiAccountModeBox"
                          Width="240"
                          HorizontalAlignment="Left"
                          Style="{StaticResource InputComboBox}" />
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource InfoText}"
                           Text="自动模式会根据额度与状态做更合适的选择；手动模式始终使用当前手动选中的账号。" />
              </StackPanel>

              <StackPanel Grid.Column="2">
                <TextBlock Text="系统启动" Style="{StaticResource FieldLabel}" />
                <CheckBox x:Name="StartupBox"
                          Content="登录 Windows 时自动启动 CodexBar"
                          Margin="0,8,0,0" />
                <CheckBox x:Name="OverlayEnabledBox"
                          Content="打开小浮窗"
                          Margin="0,12,0,0"
                          Checked="OverlayEnabledBox_Checked"
                          Unchecked="OverlayEnabledBox_Unchecked" />
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource InfoText}"
                           Text="登录启动只影响 CodexBar 本身；小浮窗开关会立即生效，可在这里直接打开或关闭。" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCard}">
          <StackPanel>
            <TextBlock Text="账号 CSV" Style="{StaticResource SectionTitle}" />
            <CheckBox x:Name="IncludeSecretsBox"
                      Content="导出 CSV 时包含密钥"
                      Margin="0,0,0,10" />
            <StackPanel Orientation="Horizontal">
              <Button Content="导出账号"
                      Width="104"
                      Margin="0,0,8,0"
                      Style="{StaticResource ActionButton}"
                      Click="ExportAccounts_Click" />
              <Button Content="导入账号"
                      Width="104"
                      Style="{StaticResource ActionButton}"
                      Click="ImportAccounts_Click" />
            </StackPanel>
            <TextBlock Margin="0,10,0,0"
                       Style="{StaticResource InfoText}"
                       Text="默认导出不包含密钥；导入只会更新本地配置和凭据，不会重写 shared ~/.codex history pool。" />
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCard}"
                Margin="0,0,0,0"
                Background="#F7F7F7">
          <StackPanel>
            <TextBlock Text="兼容边界" Style="{StaticResource SectionTitle}" />
            <TextBlock Style="{StaticResource InfoText}" Text="切换只会更新当前激活态，影响之后的新会话。" />
            <TextBlock Margin="0,6,0,0" Style="{StaticResource InfoText}" Text="shared ~/.codex history pool 保持不拆分。" />
            <TextBlock Margin="0,6,0,0" Style="{StaticResource InfoText}" Text="sessions / archived_sessions 保持原有语义，不做改写。" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2"
            Margin="0,12,0,0"
            Padding="12"
            Background="White"
            BorderBrush="#11000000"
            BorderThickness="1"
            CornerRadius="8">
      <TextBlock x:Name="StatusText"
                 Foreground="#605E5C"
                 FontSize="11"
                 TextWrapping="Wrap"
                 Text="就绪。" />
    </Border>

    <Border Grid.Row="3"
            Margin="0,12,0,0"
            Padding="12"
            Background="White"
            BorderBrush="#11000000"
            BorderThickness="1"
            CornerRadius="8">
      <DockPanel LastChildFill="False">
        <TextBlock DockPanel.Dock="Left"
                   VerticalAlignment="Center"
                   Foreground="#605E5C"
                   FontSize="10"
                   Text="保存后继续作为独立设置窗口工作，不会把它改成主浮窗里的路由页。" />
        <StackPanel DockPanel.Dock="Right"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
          <Button Content="取消"
                  Width="78"
                  Margin="0,0,8,0"
                  Style="{StaticResource SubtleButton}"
                  Click="Cancel_Click" />
          <Button Content="保存"
                  Width="78"
                  Style="{StaticResource PrimaryButton}"
                  Click="Save_Click" />
        </StackPanel>
      </DockPanel>
    </Border>
  </Grid>
</Window>
