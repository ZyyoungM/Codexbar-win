<Window x:Class="CodexBar.Win.OAuthDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登录 OpenAI 账号"
        Width="660"
        Height="620"
        MinWidth="540"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="#FFF5F5F5"
        FontFamily="Microsoft YaHei UI"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
  <Window.Resources>
    <Style x:Key="SectionCard" TargetType="Border">
      <Setter Property="Padding" Value="14" />
      <Setter Property="Margin" Value="0,0,0,12" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#11000000" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#1C1C1C" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#605E5C" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="InputTextBox" TargetType="TextBox">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="BorderBrush" Value="#D9D9D9" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="#1C1C1C" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="ActionButton" TargetType="Button">
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#1C1C1C" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#D9D9D9" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="#0067C0" />
      <Setter Property="BorderBrush" Value="#0067C0" />
    </Style>

    <Style x:Key="SubtleButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
      <Setter Property="Background" Value="#FFF5F5F5" />
      <Setter Property="BorderBrush" Value="#FFF5F5F5" />
      <Setter Property="FontWeight" Value="Normal" />
    </Style>
  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Style="{StaticResource SectionCard}"
            Background="#F7FAFF"
            BorderBrush="#CFE4F9">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock Text="登录 OpenAI 账号"
                     Foreground="#1C1C1C"
                     FontSize="17"
                     FontWeight="SemiBold" />
          <TextBlock Margin="0,6,0,0"
                     Text="通过浏览器完成 OpenAI OAuth 授权。CodexBar 会优先监听 localhost 回调；如果自动回调失败，可以手工粘贴完整 callback URL 或单独的 code。"
                     Foreground="#605E5C"
                     FontSize="11"
                     TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Column="1"
                Margin="12,0,0,0"
                Padding="8,3"
                Background="#E7F1FB"
                CornerRadius="8"
                VerticalAlignment="Top">
          <TextBlock Text="OAuth"
                     Foreground="#0067C0"
                     FontSize="10"
                     FontWeight="SemiBold" />
        </Border>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel>
        <Border Style="{StaticResource SectionCard}">
          <StackPanel>
            <TextBlock Text="授权入口" Style="{StaticResource SectionTitle}" />
            <TextBlock Text="授权 URL（只读）" Style="{StaticResource FieldLabel}" />
            <TextBox x:Name="UrlBox"
                     Style="{StaticResource InputTextBox}"
                     IsReadOnly="True"
                     MinHeight="86"
                     TextWrapping="Wrap"
                     AcceptsReturn="True" />
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
              <Button x:Name="OpenBrowserButton"
                      Content="打开浏览器"
                      Width="104"
                      Margin="0,0,8,0"
                      Style="{StaticResource PrimaryButton}"
                      Click="OpenBrowser_Click" />
              <Button x:Name="ListenButton"
                      Content="监听 localhost:1455"
                      Width="136"
                      Style="{StaticResource ActionButton}"
                      Click="Listen_Click" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border x:Name="StatusPanel"
                Style="{StaticResource SectionCard}"
                Background="#F7FAFF"
                BorderBrush="#CFE4F9">
          <StackPanel Orientation="Horizontal">
            <Ellipse x:Name="StatusDot"
                     Width="9"
                     Height="9"
                     Margin="0,2,8,0"
                     Fill="#0F6CBD"
                     VerticalAlignment="Top" />
            <StackPanel>
              <TextBlock x:Name="StatusTitleText"
                         Foreground="#0F6CBD"
                         FontSize="12"
                         FontWeight="SemiBold"
                         Text="等待授权" />
              <TextBlock x:Name="StatusBodyText"
                         Margin="0,6,0,0"
                         Foreground="#605E5C"
                         FontSize="11"
                         TextWrapping="Wrap"
                         Text="点击“打开浏览器”开始授权，或先手动开始监听回调。" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCard}">
          <StackPanel>
            <TextBlock Text="手工回调 fallback" Style="{StaticResource SectionTitle}" />
            <TextBlock Text="完整 callback URL 或 authorization code" Style="{StaticResource FieldLabel}" />
            <TextBox x:Name="CallbackBox"
                     Style="{StaticResource InputTextBox}"
                     MinHeight="96"
                     TextWrapping="Wrap"
                     AcceptsReturn="True" />
            <TextBlock Margin="0,8,0,0"
                       Foreground="#8A8886"
                       FontSize="10"
                       Text="如果浏览器没有自动回调，请把地址栏里的完整 URL 或 code 粘贴到这里。" />
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCard}"
                Margin="0,0,0,0">
          <StackPanel>
            <TextBlock Text="账号显示" Style="{StaticResource SectionTitle}" />
            <TextBlock Text="账号显示名（可选）" Style="{StaticResource FieldLabel}" />
            <TextBox x:Name="LabelBox"
                     Style="{StaticResource InputTextBox}"
                     Text="OpenAI" />
            <TextBlock Margin="0,8,0,0"
                       Foreground="#8A8886"
                       FontSize="10"
                       Text="保留为 OpenAI 时，会优先使用 OAuth 返回的邮箱或姓名。" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2"
            Margin="0,12,0,0"
            Padding="12"
            Background="White"
            BorderBrush="#11000000"
            BorderThickness="1"
            CornerRadius="8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock VerticalAlignment="Center"
                   Foreground="#605E5C"
                   FontSize="10"
                   Text="浏览器授权 + localhost callback + 手工粘贴 fallback 会同时保留。" />

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
          <Button Content="取消"
                  Width="78"
                  Margin="0,0,8,0"
                  Style="{StaticResource SubtleButton}"
                  Click="Cancel_Click" />
          <Button x:Name="CompleteButton"
                  Content="完成登录"
                  Width="92"
                  Style="{StaticResource PrimaryButton}"
                  Click="Complete_Click" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
